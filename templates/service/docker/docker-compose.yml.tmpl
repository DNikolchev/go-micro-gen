version: "3.9"

services:
  # ─── Application ─────────────────────────────────────────────────────────────
  {{replace .ServiceName "-" "_"}}:
    build:
      context: .
      dockerfile: docker/Dockerfile
    container_name: {{.ServiceName}}
    restart: unless-stopped
    ports:
      - "8080:8080"
    env_file:
      - .env
    environment:
      OTEL_EXPORTER_OTLP_ENDPOINT: otel-collector:4317
{{- if isPostgres .Database}}
      DB_HOST: postgres
      DB_PORT: "5432"
      DB_NAME: ${DB_NAME:-{{replace .ServiceName "-" "_"}}}
      DB_USER: ${DB_USER:-postgres}
      DB_PASSWORD: ${DB_PASSWORD:-postgres}
      DB_SSLMODE: disable
{{- end}}
{{- if isMongo .Database}}
      MONGO_URI: mongodb://mongo:27017
      MONGO_DB: ${MONGO_DB:-{{replace .ServiceName "-" "_"}}}
{{- end}}
{{- if .IncludeRedis}}
      REDIS_ADDR: redis:6379
{{- end}}
    depends_on:
{{- if isPostgres .Database}}
      postgres:
        condition: service_healthy
{{- end}}
{{- if isMongo .Database}}
      mongo:
        condition: service_healthy
{{- end}}
{{- if .IncludeRedis}}
      redis:
        condition: service_healthy
{{- end}}
      otel-collector:
        condition: service_started
    networks:
      - {{.ServiceName}}-net

{{- if isPostgres .Database}}
  # ─── PostgreSQL ────────────────────────────────────────────────────────────
  postgres:
    image: postgres:16-alpine
    container_name: {{.ServiceName}}-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${DB_USER:-postgres}
      POSTGRES_PASSWORD: ${DB_PASSWORD:-postgres}
      POSTGRES_DB: ${DB_NAME:-{{replace .ServiceName "-" "_"}}}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 10
    networks:
      - {{.ServiceName}}-net
{{- end}}

{{- if isMongo .Database}}
  # ─── MongoDB ───────────────────────────────────────────────────────────────
  mongo:
    image: mongo:7
    container_name: {{.ServiceName}}-mongo
    restart: unless-stopped
    environment:
      MONGO_INITDB_DATABASE: ${MONGO_DB:-{{replace .ServiceName "-" "_"}}}
    volumes:
      - mongo_data:/data/db
    ports:
      - "27017:27017"
    healthcheck:
      test: ["CMD", "mongosh", "--eval", "db.adminCommand('ping')"]
      interval: 5s
      timeout: 5s
      retries: 10
    networks:
      - {{.ServiceName}}-net
{{- end}}

{{- if .IncludeRedis}}
  # ─── Redis ────────────────────────────────────────────────────────────────
  redis:
    image: redis:7-alpine
    container_name: {{.ServiceName}}-redis
    restart: unless-stopped
    volumes:
      - redis_data:/data
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
    networks:
      - {{.ServiceName}}-net
{{- end}}

  # ─── OpenTelemetry Collector ──────────────────────────────────────────────
  otel-collector:
    image: otel/opentelemetry-collector-contrib:latest
    container_name: {{.ServiceName}}-otel-collector
    restart: unless-stopped
    command: ["--config=/etc/otel/config.yml"]
    volumes:
      - ./docker/configs/otel-collector-config.yml:/etc/otel/config.yml:ro
    ports:
      - "4317:4317"   # OTLP gRPC
      - "4318:4318"   # OTLP HTTP
      - "8889:8889"   # Prometheus metrics
    networks:
      - {{.ServiceName}}-net

  # ─── Prometheus ───────────────────────────────────────────────────────────
  prometheus:
    image: prom/prometheus:latest
    container_name: {{.ServiceName}}-prometheus
    restart: unless-stopped
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.retention.time=7d'
    volumes:
      - ./docker/configs/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus_data:/prometheus
    ports:
      - "9090:9090"
    networks:
      - {{.ServiceName}}-net

  # ─── Grafana ──────────────────────────────────────────────────────────────
  grafana:
    image: grafana/grafana:latest
    container_name: {{.ServiceName}}-grafana
    restart: unless-stopped
    environment:
      GF_SECURITY_ADMIN_USER: admin
      GF_SECURITY_ADMIN_PASSWORD: admin
      GF_USERS_ALLOW_SIGN_UP: "false"
    volumes:
      - grafana_data:/var/lib/grafana
      - ./docker/configs/grafana/provisioning:/etc/grafana/provisioning:ro
    ports:
      - "3000:3000"
    depends_on:
      - prometheus
    networks:
      - {{.ServiceName}}-net

# ─── Volumes ───────────────────────────────────────────────────────────────────
volumes:
{{- if isPostgres .Database}}
  postgres_data:
{{- end}}
{{- if isMongo .Database}}
  mongo_data:
{{- end}}
{{- if .IncludeRedis}}
  redis_data:
{{- end}}
  prometheus_data:
  grafana_data:

# ─── Networks ──────────────────────────────────────────────────────────────────
networks:
  {{.ServiceName}}-net:
    driver: bridge
