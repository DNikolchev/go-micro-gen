package main

import (
	"context"
	"fmt"
	"log/slog"
	"net"
{{- if isHTTP .Transport}}
	"net/http"
{{- end}}
	"os"
	"os/signal"
	"syscall"
	"time"

	"{{.ModulePath}}/internal/config"
	"{{.ModulePath}}/{{.Arch.Service}}"
{{- if hasDB .Database}}
	"{{.ModulePath}}/{{.Arch.Repository}}/{{.Database}}"
{{- end}}
{{- if isHTTP .Transport}}
	"{{.ModulePath}}/{{.Arch.Transport}}/httpx"
{{- end}}
{{- if isGRPC .Transport}}
	"{{.ModulePath}}/{{.Arch.Transport}}/grpc"
	grpc_lib "google.golang.org/grpc"
{{- end}}
{{- if hasBroker .Broker}}
	"{{.ModulePath}}/internal/broker/{{.Broker}}"
{{- end}}
	"{{.ModulePath}}/pkg/health"
	"{{.ModulePath}}/pkg/logger"
	"{{.ModulePath}}/pkg/telemetry"
)

func main() {
	// Load configuration
	cfg := config.MustLoad()

	// Initialize structured logger
	log := logger.New(cfg.LogLevel)
	slog.SetDefault(log)

	// Initialize OpenTelemetry
	otelShutdown, err := telemetry.Setup(context.Background(), "{{.ServiceName}}", cfg.OTELEndpoint)
	if err != nil {
		slog.Error("failed to setup OpenTelemetry", "error", err)
		os.Exit(1)
	}
	defer func() {
		if err := otelShutdown(context.Background()); err != nil {
			slog.Error("failed to shutdown OpenTelemetry", "error", err)
		}
	}()

	slog.Info("starting {{.ServiceName}}", "version", cfg.Version, "port", cfg.Port)

{{- if eq .Cloud "aws"}}
	// Initialize AWS
	_, err = config.InitAWS(context.Background(), log)
	if err != nil {
		slog.Error("failed to initialize AWS", "error", err)
	}
{{- end}}
{{- if eq .Cloud "gcp"}}
	// Initialize GCP
	_, err = config.InitGCP(context.Background(), log)
	if err != nil {
		slog.Error("failed to initialize GCP", "error", err)
	}
{{- end}}

{{- if hasDB .Database}}
	// Initialize repository
	repo, err := {{.Database}}.NewRepository(cfg)
	if err != nil {
		slog.Error("failed to connect to database", "error", err)
		os.Exit(1)
	}
	defer repo.Close()

	// Initialize service
	svc := service.New(repo, log)
{{- else}}
	// Initialize service (no database)
	svc := service.New(log)
{{- end}}

{{- if hasBroker .Broker}}
	// Initialize Message Broker
	brokerClient, err := {{.Broker}}.NewClient(cfg, log)
	if err != nil {
		slog.Error("failed to connect to message broker", "error", err)
		os.Exit(1)
	}
	defer brokerClient.Close()
{{- end}}

{{- if isHTTP .Transport}}
	// Initialize HTTP router
	router := httpx.NewRouter(svc, log)

	// Add health endpoints
	health.Register(router, cfg)

	// Start HTTP server with graceful shutdown
	httpSrv := &http.Server{
		Addr:         fmt.Sprintf(":%d", cfg.Port),
		Handler:      router,
		ReadTimeout:  15 * time.Second,
		WriteTimeout: 15 * time.Second,
		IdleTimeout:  60 * time.Second,
	}

	// Start server in a goroutine
	go func() {
		slog.Info("HTTP server listening", "addr", httpSrv.Addr)
		if err := httpSrv.ListenAndServe(); err != nil && err != http.ErrServerClosed {
			slog.Error("HTTP server error", "error", err)
			os.Exit(1)
		}
	}()
{{- end}}

{{- if isGRPC .Transport}}
	// Initialize gRPC Server
	grpcSrv := grpc.NewServer(svc, log)
	grpcLis, err := net.Listen("tcp", fmt.Sprintf(":%d", cfg.Port+1000))
	if err != nil {
		slog.Error("failed to listen for gRPC", "error", err)
		os.Exit(1)
	}
	
	go func() {
		slog.Info("gRPC server listening", "addr", grpcLis.Addr())
		if err := grpcSrv.Serve(grpcLis); err != nil {
			slog.Error("gRPC server error", "error", err)
			os.Exit(1)
		}
	}()
{{- end}}

	// Graceful shutdown on SIGINT / SIGTERM
	quit := make(chan os.Signal, 1)
	signal.Notify(quit, syscall.SIGINT, syscall.SIGTERM)
	<-quit

	slog.Info("shutting down gracefully...")
{{- if isHTTP .Transport}}
	ctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)
	defer cancel()

	if err := httpSrv.Shutdown(ctx); err != nil {
		slog.Error("HTTP server forced shutdown", "error", err)
	}
{{- end}}
{{- if isGRPC .Transport}}
	grpcSrv.GracefulStop()
{{- end}}
	slog.Info("server stopped")
}
