package service

import (
	"context"
	"fmt"
	"log/slog"

{{- if hasDB .Database}}
	"{{.ModulePath}}/{{.Arch.Repository}}"
{{- end}}
	"{{.ModulePath}}/{{.Arch.Domain}}"
)

// Service contains the core business logic for {{.ServiceName}}.
// This layer MUST be database-agnostic — it depends only on the Repository interface.
type Service struct {
{{- if hasDB .Database}}
	repo repository.Repository
{{- end}}
	log  *slog.Logger
}

// New creates a new Service.
{{- if hasDB .Database}}
func New(repo repository.Repository, log *slog.Logger) *Service {
	return &Service{repo: repo, log: log}
}
{{- else}}
func New(log *slog.Logger) *Service {
	return &Service{log: log}
}
{{- end}}

// Create creates a new Example entity.
func (s *Service) Create(ctx context.Context, e *domain.Example) (*domain.Example, error) {
	s.log.InfoContext(ctx, "creating example", "name", e.Name)

	if e.Name == "" {
		return nil, fmt.Errorf("name is required")
	}

{{- if hasDB .Database}}
	result, err := s.repo.Create(ctx, e)
	if err != nil {
		return nil, fmt.Errorf("service create: %w", err)
	}
	return result, nil
{{- else}}
	// TODO: implement business logic
	return e, nil
{{- end}}
}

// GetByID retrieves an Example by its ID.
func (s *Service) GetByID(ctx context.Context, id string) (*domain.Example, error) {
	s.log.InfoContext(ctx, "getting example", "id", id)
{{- if hasDB .Database}}
	return s.repo.GetByID(ctx, id)
{{- else}}
	// TODO: implement business logic
	return &domain.Example{ID: id}, nil
{{- end}}
}

// List returns all Example entities.
func (s *Service) List(ctx context.Context) ([]*domain.Example, error) {
	s.log.InfoContext(ctx, "listing examples")
{{- if hasDB .Database}}
	return s.repo.List(ctx)
{{- else}}
	return nil, nil
{{- end}}
}

// Update modifies an existing Example entity.
func (s *Service) Update(ctx context.Context, e *domain.Example) (*domain.Example, error) {
	s.log.InfoContext(ctx, "updating example", "id", e.ID)
{{- if hasDB .Database}}
	return s.repo.Update(ctx, e)
{{- else}}
	return e, nil
{{- end}}
}

// Delete removes an Example entity by its ID.
func (s *Service) Delete(ctx context.Context, id string) error {
	s.log.InfoContext(ctx, "deleting example", "id", id)
{{- if hasDB .Database}}
	return s.repo.Delete(ctx, id)
{{- else}}
	return nil
{{- end}}
}
