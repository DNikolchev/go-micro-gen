package postgres

import (
	"context"
	"database/sql"
	"fmt"
	"time"

	_ "github.com/lib/pq"
	"{{.ModulePath}}/internal/config"
	"{{.ModulePath}}/{{.Arch.Domain}}"
)

// Repository is the PostgreSQL implementation of repository.Repository.
type Repository struct {
	db *sql.DB
}

// NewRepository opens a PostgreSQL connection and returns a Repository.
func NewRepository(cfg *config.Config) (*Repository, error) {
	db, err := sql.Open("postgres", cfg.DSN())
	if err != nil {
		return nil, fmt.Errorf("open postgres: %w", err)
	}

	// Connection pool settings
	db.SetMaxOpenConns(25)
	db.SetMaxIdleConns(10)
	db.SetConnMaxLifetime(5 * time.Minute)

	// Verify connectivity
	ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
	defer cancel()
	if err := db.PingContext(ctx); err != nil {
		return nil, fmt.Errorf("ping postgres: %w", err)
	}

	return &Repository{db: db}, nil
}

// Close closes the database connection pool.
func (r *Repository) Close() error {
	return r.db.Close()
}

// Create inserts a new Example record into the database.
func (r *Repository) Create(ctx context.Context, e *domain.Example) (*domain.Example, error) {
	now := time.Now().UTC()
	query := `
		INSERT INTO examples (id, name, created_at, updated_at)
		VALUES (gen_random_uuid(), $1, $2, $3)
		RETURNING id, name, created_at, updated_at`

	row := r.db.QueryRowContext(ctx, query, e.Name, now, now)
	result := &domain.Example{}
	if err := row.Scan(&result.ID, &result.Name, &result.CreatedAt, &result.UpdatedAt); err != nil {
		return nil, fmt.Errorf("create example: %w", err)
	}
	return result, nil
}

// GetByID retrieves an Example by its UUID.
func (r *Repository) GetByID(ctx context.Context, id string) (*domain.Example, error) {
	query := `SELECT id, name, created_at, updated_at FROM examples WHERE id = $1`
	row := r.db.QueryRowContext(ctx, query, id)

	result := &domain.Example{}
	if err := row.Scan(&result.ID, &result.Name, &result.CreatedAt, &result.UpdatedAt); err != nil {
		if err == sql.ErrNoRows {
			return nil, fmt.Errorf("example %s not found", id)
		}
		return nil, fmt.Errorf("get example: %w", err)
	}
	return result, nil
}

// List returns all Example records.
func (r *Repository) List(ctx context.Context) ([]*domain.Example, error) {
	query := `SELECT id, name, created_at, updated_at FROM examples ORDER BY created_at DESC`
	rows, err := r.db.QueryContext(ctx, query)
	if err != nil {
		return nil, fmt.Errorf("list examples: %w", err)
	}
	defer rows.Close()

	var results []*domain.Example
	for rows.Next() {
		e := &domain.Example{}
		if err := rows.Scan(&e.ID, &e.Name, &e.CreatedAt, &e.UpdatedAt); err != nil {
			return nil, fmt.Errorf("scan example: %w", err)
		}
		results = append(results, e)
	}
	return results, rows.Err()
}

// Update modifies an existing Example record.
func (r *Repository) Update(ctx context.Context, e *domain.Example) (*domain.Example, error) {
	query := `
		UPDATE examples SET name = $1, updated_at = $2
		WHERE id = $3
		RETURNING id, name, created_at, updated_at`

	row := r.db.QueryRowContext(ctx, query, e.Name, time.Now().UTC(), e.ID)
	result := &domain.Example{}
	if err := row.Scan(&result.ID, &result.Name, &result.CreatedAt, &result.UpdatedAt); err != nil {
		return nil, fmt.Errorf("update example: %w", err)
	}
	return result, nil
}

// Delete removes an Example by its ID.
func (r *Repository) Delete(ctx context.Context, id string) error {
	_, err := r.db.ExecContext(ctx, `DELETE FROM examples WHERE id = $1`, id)
	return err
}
