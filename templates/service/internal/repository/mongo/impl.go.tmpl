package mongo

import (
	"context"
	"fmt"
	"time"

	"go.mongodb.org/mongo-driver/bson"
	"go.mongodb.org/mongo-driver/bson/primitive"
	"go.mongodb.org/mongo-driver/mongo"
	"go.mongodb.org/mongo-driver/mongo/options"
	"go.mongodb.org/mongo-driver/mongo/readpref"
	"{{.ModulePath}}/internal/config"
	"{{.ModulePath}}/{{.Arch.Domain}}"
)

const collectionName = "examples"

// Repository is the MongoDB implementation of repository.Repository.
type Repository struct {
	client *mongo.Client
	coll   *mongo.Collection
}

// NewRepository creates a MongoDB client and returns a Repository.
func NewRepository(cfg *config.Config) (*Repository, error) {
	ctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)
	defer cancel()

	client, err := mongo.Connect(ctx, options.Client().ApplyURI(cfg.MongoURI))
	if err != nil {
		return nil, fmt.Errorf("connect mongo: %w", err)
	}

	if err := client.Ping(ctx, readpref.Primary()); err != nil {
		return nil, fmt.Errorf("ping mongo: %w", err)
	}

	coll := client.Database(cfg.MongoDB).Collection(collectionName)
	return &Repository{client: client, coll: coll}, nil
}

// Close disconnects from MongoDB.
func (r *Repository) Close() error {
	ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
	defer cancel()
	return r.client.Disconnect(ctx)
}

// Create inserts a new Example document.
func (r *Repository) Create(ctx context.Context, e *domain.Example) (*domain.Example, error) {
	now := time.Now().UTC()
	e.ID = primitive.NewObjectID().Hex()
	e.CreatedAt = now
	e.UpdatedAt = now

	if _, err := r.coll.InsertOne(ctx, e); err != nil {
		return nil, fmt.Errorf("mongo insert: %w", err)
	}
	return e, nil
}

// GetByID retrieves an Example by its ID.
func (r *Repository) GetByID(ctx context.Context, id string) (*domain.Example, error) {
	result := &domain.Example{}
	if err := r.coll.FindOne(ctx, bson.M{"id": id}).Decode(result); err != nil {
		if err == mongo.ErrNoDocuments {
			return nil, fmt.Errorf("example %s not found", id)
		}
		return nil, fmt.Errorf("mongo findOne: %w", err)
	}
	return result, nil
}

// List returns all Example documents.
func (r *Repository) List(ctx context.Context) ([]*domain.Example, error) {
	cursor, err := r.coll.Find(ctx, bson.M{})
	if err != nil {
		return nil, fmt.Errorf("mongo find: %w", err)
	}
	defer cursor.Close(ctx)

	var results []*domain.Example
	if err := cursor.All(ctx, &results); err != nil {
		return nil, fmt.Errorf("mongo decode: %w", err)
	}
	return results, nil
}

// Update replaces an existing Example document.
func (r *Repository) Update(ctx context.Context, e *domain.Example) (*domain.Example, error) {
	e.UpdatedAt = time.Now().UTC()
	update := bson.M{"$set": e}
	_, err := r.coll.UpdateOne(ctx, bson.M{"id": e.ID}, update)
	if err != nil {
		return nil, fmt.Errorf("mongo update: %w", err)
	}
	return e, nil
}

// Delete removes an Example document by its ID.
func (r *Repository) Delete(ctx context.Context, id string) error {
	_, err := r.coll.DeleteOne(ctx, bson.M{"id": id})
	return err
}
