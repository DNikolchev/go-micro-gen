apiVersion: v1
kind: Service
metadata:
  name: {{ "{{" }} include "{{.ServiceName}}.fullname" . {{ "}}" }}
  labels:
    app: {{ "{{" }} include "{{.ServiceName}}.fullname" . {{ "}}" }}
spec:
  type: {{ "{{" }} .Values.service.type {{ "}}" }}
  ports:
    - port: {{ "{{" }} .Values.service.port {{ "}}" }}
      targetPort: http
      protocol: TCP
      name: http
  selector:
    app: {{ "{{" }} include "{{.ServiceName}}.fullname" . {{ "}}" }}
