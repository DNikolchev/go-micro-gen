run:
  concurrency: 4
  timeout: 5m
  issues-exit-code: 1

linters:
  enable-all: false
  enable:
    - gofmt
    - goimports
    - govet
    - errcheck
    - staticcheck
    - unused
    - gosimple
    - ineffassign
    - typecheck
    - gosec
    - misspell
    - gocritic
    - godot
    - noctx
    - bodyclose
    - contextcheck
    - exhaustive
    - prealloc
    - exportloopref

linters-settings:
  goimports:
    local-prefixes: {{.ModulePath}}
  gocritic:
    enabled-tags:
      - performance
      - style
      - diagnostic
  gosec:
    excludes:
      - G104  # Errors unhandled (too noisy for some ops)

issues:
  exclude-rules:
    - path: "_test\\.go"
      linters:
        - gosec
        - errcheck
  max-issues-per-linter: 0
  max-same-issues: 0
